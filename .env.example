# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# S3 Buckets (from Terraform outputs)
S3_BUCKET_IMAGES=smart-vendors-images-dev
S3_BUCKET_STATIC=smart-vendors-static-dev
S3_BUCKET_ML_MODELS=smart-vendors-ml-models-dev

# DynamoDB Tables (from Terraform outputs)
DYNAMODB_TABLE_VENDORS=smart-vendors-vendors-dev
DYNAMODB_TABLE_TRANSACTIONS=smart-vendors-transactions-dev
DYNAMODB_TABLE_MARKET_PRICES=smart-vendors-market-prices-dev
DYNAMODB_TABLE_MARKETPLACE_LISTINGS=smart-vendors-marketplace-listings-dev

# Lambda Configuration
LAMBDA_EXECUTION_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/smart-vendors-lambda-execution-dev

# API Configuration
API_GATEWAY_ENDPOINT=https://xxxxxxxxxx.execute-api.ap-south-1.amazonaws.com

# Frontend Configuration
CLOUDFRONT_DOMAIN=xxxxxxxxxx.cloudfront.net

# Demo Credentials
DEMO_VENDOR_USERNAME=demo_vendor
DEMO_VENDOR_PASSWORD=hackathon2024

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-v2

# SageMaker Configuration
SAGEMAKER_ENDPOINT_NAME=produce-freshness-classifier
# Set to true to use mock classification (no SageMaker endpoint required)
DEMO_MODE=true

# Application Configuration
ENVIRONMENT=dev
LOG_LEVEL=INFO
